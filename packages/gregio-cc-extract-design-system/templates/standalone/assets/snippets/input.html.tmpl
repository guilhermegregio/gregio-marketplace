<!-- Inputs -->

<div class="ds-field">
  <label for="name" class="ds-label">Nome</label>
  <input id="name" name="name" type="text" class="ds-input" placeholder="Seu nome" required />
</div>

<div class="ds-field">
  <label for="email" class="ds-label">Email</label>
  <input id="email" name="email" type="email" class="ds-input is-error" />
  <p class="ds-field-error">Email inválido</p>
</div>

<!-- Checkbox -->
<label class="ds-checkbox">
  <input type="checkbox" />
  <span class="ds-checkbox-mark"></span>
  <span>Aceito os termos</span>
</label>

<!-- Toggle -->
<label class="ds-toggle">
  <input type="checkbox" />
  <span class="ds-toggle-track"><span class="ds-toggle-thumb"></span></span>
  <span>Notificações</span>
</label>
