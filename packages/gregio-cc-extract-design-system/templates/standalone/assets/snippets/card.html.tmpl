<!-- Card variants -->

<!-- Default -->
<article class="ds-card p-6">
  <h3 class="ds-h4">Título</h3>
  <p class="ds-body">Conteúdo do card.</p>
</article>

<!-- Product (image on top, body, footer) -->
<article class="ds-card ds-card-product">
  <img src="/assets/product.jpg" alt="Produto" />
  <div class="ds-card-body">
    <h3 class="ds-h4">Nome do produto</h3>
    <p class="ds-body-sm">Descrição curta.</p>
  </div>
  <div class="ds-card-footer">
    <span class="ds-label">R$ 00,00</span>
    <a class="ds-btn ds-btn-primary ds-btn-sm" href="#">Comprar</a>
  </div>
</article>

<!-- Glass (overlay on image) -->
<article class="ds-card ds-card-glass p-6">
  <h3 class="ds-h4">Glass card</h3>
  <p class="ds-body">Usar sobre fundos com imagem para contraste translúcido.</p>
</article>

<!-- Flashlight (hover effect that follows cursor) -->
<article class="ds-card ds-card-flashlight p-6">
  <h3 class="ds-h4">Flashlight</h3>
  <p class="ds-body">Destaca conteúdo com gradiente seguindo o cursor.</p>
</article>
