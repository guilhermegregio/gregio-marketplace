<!-- Button — preserve classes exactly -->

<!-- Primary -->
<a class="ds-btn ds-btn-primary" href="#">Call to action</a>

<!-- Secondary -->
<button class="ds-btn ds-btn-secondary" type="button">Secondary</button>

<!-- Ghost -->
<button class="ds-btn ds-btn-ghost" type="button">Ghost</button>

<!-- With icon (replace the svg with your icon system) -->
<a class="ds-btn ds-btn-primary" href="#">
  <svg aria-hidden="true" width="16" height="16"><!-- icon --></svg>
  <span>Comprar</span>
</a>

<!-- Disabled -->
<button class="ds-btn ds-btn-primary" disabled>Indisponível</button>

<!-- Loading -->
<button class="ds-btn ds-btn-primary is-loading" aria-busy="true">Enviando…</button>
