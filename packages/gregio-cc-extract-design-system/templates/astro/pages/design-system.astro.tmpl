---
/*
 * Design System — living showcase
 * Generated by gregio-cc-extract-design-system.
 * Edit the ds-* CSS files in src/styles/design-system/ and the
 * Astro components in src/components/ds/ to evolve the system.
 */
import BaseLayout from '{{../layouts/BaseLayout.astro | ../../layouts/BaseLayout.astro}}';
import Button from '../components/ds/Button.astro';
import Card from '../components/ds/Card.astro';
import Badge from '../components/ds/Badge.astro';
import Input from '../components/ds/Input.astro';
import Nav from '../components/ds/Nav.astro';
import Hero from '../components/ds/Hero.astro';
// import { Icon } from 'astro-icon/components';  // uncomment if the source uses astro-icon

const navLinks = [
  { href: '#typography', label: 'Tipografia' },
  { href: '#colors', label: 'Cores' },
  { href: '#components', label: 'Componentes' },
  { href: '#icons', label: 'Ícones' },
  { href: '#animations', label: 'Animações' },
  { href: '#layout', label: 'Layout' },
];
---

<BaseLayout title="{{PROJECT_NAME}} — Design System">
  <Nav links={navLinks} logoSrc="{{/assets/logo.png}}" logoAlt="{{PROJECT_NAME}}" />

  <!-- 0) HERO (exact clone of source site's hero, text adapted) -->
  <Hero
    eyebrow="Design System"
    title="{{PROJECT_NAME}} Design System"
    subtitle="Fonte única de verdade: tokens, componentes, tipografia e animações."
  >
    <a slot="cta" href="#typography"><Button variant="primary">Explorar</Button></a>
    <a slot="cta" href="#colors"><Button variant="secondary">Cores & Tokens</Button></a>
  </Hero>

  <!-- 1) TYPOGRAPHY -->
  <section id="typography" class="ds-section">
    <div class="ds-container">
      <header class="ds-section-header reveal-up">
        <Badge variant="label" dot>01 — Tipografia</Badge>
        <h2 class="ds-h1 ds-text-gradient">Tipografia</h2>
        <p class="ds-body-lg mt-4">{{hierarquia, escala, ritmo}}</p>
      </header>

      <div class="ds-type-spec">
        <div class="ds-type-row">
          <span class="ds-label">Heading 1</span>
          <h1 class="ds-h1">{{Exemplo de H1}}</h1>
          <span class="ds-type-size">{{40px}} / {{48px}}</span>
        </div>
        <!-- Repeat for H2, H3, H4, Body L/M/S, Label.
             Include ONLY styles that exist in the source site. -->
      </div>
    </div>
  </section>

  <!-- 2) COLORS & SURFACES -->
  <section id="colors" class="ds-section">
    <div class="ds-container">
      <header class="ds-section-header reveal-up">
        <Badge variant="label" dot>02 — Cores</Badge>
        <h2 class="ds-h1 ds-text-gradient">Cores & Superfícies</h2>
      </header>
      <div class="ds-grid-4">
        <!-- swatch cards: swatch + name + var(--...) + hex + usage -->
        <Card variant="default">
          <div class="ds-swatch" style="background: var(--{{prefix}}-{{name}})"></div>
          <p class="ds-label">{{Nome}}</p>
          <code>var(--{{prefix}}-{{name}})</code>
          <p class="ds-body-sm">{{Uso canônico}}</p>
        </Card>
      </div>
    </div>
  </section>

  <!-- 3) UI COMPONENTS -->
  <section id="components" class="ds-section">
    <div class="ds-container">
      <header class="ds-section-header reveal-up">
        <Badge variant="label" dot>03 — Componentes</Badge>
        <h2 class="ds-h1 ds-text-gradient">Componentes</h2>
      </header>

      <h3 class="ds-h3">Buttons</h3>
      <div class="flex flex-wrap gap-4 mb-12">
        <Button variant="primary">Primary</Button>
        <Button variant="secondary">Secondary</Button>
        <Button variant="ghost">Ghost</Button>
        <Button variant="primary" disabled>Disabled</Button>
        <Button variant="primary" loading>Loading</Button>
      </div>

      <h3 class="ds-h3">Cards</h3>
      <div class="ds-grid-3 mb-12">
        <Card variant="default">Default card</Card>
        <Card variant="glass">Glass card</Card>
        <Card variant="flashlight">Flashlight card</Card>
      </div>

      <h3 class="ds-h3">Inputs</h3>
      <div class="ds-grid-2 mb-12">
        <Input name="ex-name" label="Nome" placeholder="Seu nome" />
        <Input name="ex-email" label="Email" type="email" error="Email inválido" />
      </div>

      <h3 class="ds-h3">Badges</h3>
      <div class="flex flex-wrap gap-3 mb-12">
        <Badge>Default</Badge>
        <Badge variant="primary" dot>Primary</Badge>
        <Badge variant="accent">Accent</Badge>
      </div>
    </div>
  </section>

  <!-- 4) LAYOUT & SPACING -->
  <section id="layout" class="ds-section">
    <div class="ds-container">
      <header class="ds-section-header reveal-up">
        <Badge variant="label" dot>04 — Layout</Badge>
        <h2 class="ds-h1 ds-text-gradient">Layout & Espaçamento</h2>
      </header>
      <!-- Show 2–3 real layout patterns from the source site -->
    </div>
  </section>

  <!-- 5) MOTION -->
  <section id="animations" class="ds-section">
    <div class="ds-container">
      <header class="ds-section-header reveal-up">
        <Badge variant="label" dot>05 — Motion</Badge>
        <h2 class="ds-h1 ds-text-gradient">Animações</h2>
      </header>
      <div class="ds-grid-3">
        <Card><div class="reveal-up is-visible">reveal-up</div></Card>
        <Card><div class="reveal-zoom is-visible">reveal-zoom</div></Card>
        <Card><div class="ds-float">float</div></Card>
      </div>
    </div>
  </section>

  <!-- 6) ICONS (remove section if source doesn't use icons) -->
  <section id="icons" class="ds-section">
    <div class="ds-container">
      <header class="ds-section-header reveal-up">
        <Badge variant="label" dot>06 — Ícones</Badge>
        <h2 class="ds-h1 ds-text-gradient">Ícones</h2>
      </header>
      <!-- <Icon name="solar:heart-bold" class="w-8 h-8" /> -->
    </div>
  </section>
</BaseLayout>

<script>
  // Reveal on scroll — matches reveal-up/zoom/left/right classes in animations.css
  const io = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          io.unobserve(e.target);
        }
      }
    },
    { threshold: 0.15 }
  );
  document.querySelectorAll('.reveal-up, .reveal-zoom, .reveal-left, .reveal-right')
    .forEach((el) => io.observe(el));
</script>
