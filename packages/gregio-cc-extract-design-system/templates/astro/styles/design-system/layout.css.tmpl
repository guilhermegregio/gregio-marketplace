/* ============================================
   LAYOUT — containers, grids, sections, backgrounds
   ============================================ */

.ds-container {
  width: 100%;
  max-width: {{px}};
  margin-inline: auto;
  padding-inline: var(--space-6);
}

.ds-section {
  padding-block: var(--space-16);
}

.ds-section-header {
  text-align: center;
  max-width: {{px}};
  margin-inline: auto;
  margin-bottom: var(--space-12);
}

.ds-grid-2 { display: grid; grid-template-columns: 1fr; gap: var(--space-6); }
.ds-grid-3 { display: grid; grid-template-columns: 1fr; gap: var(--space-6); }
.ds-grid-4 { display: grid; grid-template-columns: 1fr; gap: var(--space-4); }

@media (min-width: 768px) {
  .ds-grid-2 { grid-template-columns: repeat(2, 1fr); }
  .ds-grid-3 { grid-template-columns: repeat(3, 1fr); }
  .ds-grid-4 { grid-template-columns: repeat(4, 1fr); }
}

.bg-grid {
  background-image: {{gradient-or-pattern-from-source}};
}
.bg-cream { background-color: var(--{{prefix}}-{{surface-name}}); }
