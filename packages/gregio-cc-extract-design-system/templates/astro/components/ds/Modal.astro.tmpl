---
export interface Props {
  id: string;
  title?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { id, title, size = 'md' } = Astro.props;
---

<dialog id={id} class={`ds-modal ds-modal-${size}`}>
  <form method="dialog" class="ds-modal-overlay"></form>
  <div class="ds-modal-content">
    {title && (
      <header class="ds-modal-header">
        <h3 class="ds-h3">{title}</h3>
        <button class="ds-btn-icon" data-modal-close aria-label="Fechar">×</button>
      </header>
    )}
    <div class="ds-modal-body">
      <slot />
    </div>
    <footer class="ds-modal-footer">
      <slot name="footer" />
    </footer>
  </div>
</dialog>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-modal-close]').forEach((btn) => {
    btn.addEventListener('click', () => btn.closest('dialog')?.close());
  });
</script>
