/* ═══════════════════════════════════════════
   Design Tokens — {{VALUE:project-name}}
   Source: {{VALUE:source-url}}
   ═══════════════════════════════════════════ */

:root {
  /* ─── Colors: Primary ─── */
  --color-primary:            {{VALUE:color-primary}};
  --color-primary-dark:       {{VALUE:color-primary-dark}};
  --color-primary-light:      {{VALUE:color-primary-light}};
  --color-primary-50:         {{VALUE:color-primary-50}};
  --color-primary-100:        {{VALUE:color-primary-100}};
  --color-primary-200:        {{VALUE:color-primary-200}};
  --color-primary-300:        {{VALUE:color-primary-300}};
  --color-primary-400:        {{VALUE:color-primary-400}};
  --color-primary-500:        {{VALUE:color-primary-500}};
  --color-primary-600:        {{VALUE:color-primary-600}};
  --color-primary-700:        {{VALUE:color-primary-700}};
  --color-primary-800:        {{VALUE:color-primary-800}};
  --color-primary-900:        {{VALUE:color-primary-900}};

  /* ─── Colors: Accent ─── */
  --color-accent:             {{VALUE:color-accent}};
  --color-accent-dark:        {{VALUE:color-accent-dark}};
  --color-accent-light:       {{VALUE:color-accent-light}};

  /* ─── Colors: Surfaces ─── */
  --color-surface:            {{VALUE:color-surface}};
  --color-surface-alt:        {{VALUE:color-surface-alt}};
  --color-surface-elevated:   {{VALUE:color-surface-elevated}};
  --color-background:         {{VALUE:color-background}};
  --color-overlay:            {{VALUE:color-overlay}};

  /* ─── Colors: Text ─── */
  --color-text:               {{VALUE:color-text}};
  --color-text-secondary:     {{VALUE:color-text-secondary}};
  --color-text-muted:         {{VALUE:color-text-muted}};
  --color-text-inverse:       {{VALUE:color-text-inverse}};
  --color-text-link:          {{VALUE:color-text-link}};

  /* ─── Colors: Border ─── */
  --color-border:             {{VALUE:color-border}};
  --color-border-light:       {{VALUE:color-border-light}};

  /* ─── Colors: Feedback ─── */
  --color-success:            {{VALUE:color-success}};
  --color-success-light:      {{VALUE:color-success-light}};
  --color-warning:            {{VALUE:color-warning}};
  --color-warning-light:      {{VALUE:color-warning-light}};
  --color-error:              {{VALUE:color-error}};
  --color-error-light:        {{VALUE:color-error-light}};
  --color-info:               {{VALUE:color-info}};
  --color-info-light:         {{VALUE:color-info-light}};

  /* ─── Fonts ─── */
  --font-display:             {{VALUE:font-display}};
  --font-primary:             {{VALUE:font-primary}};
  --font-mono:                {{VALUE:font-mono}};

  /* ─── Spacing Scale ─── */
  --space-1:                  {{VALUE:space-1}};
  --space-2:                  {{VALUE:space-2}};
  --space-3:                  {{VALUE:space-3}};
  --space-4:                  {{VALUE:space-4}};
  --space-5:                  {{VALUE:space-5}};
  --space-6:                  {{VALUE:space-6}};
  --space-8:                  {{VALUE:space-8}};
  --space-10:                 {{VALUE:space-10}};
  --space-12:                 {{VALUE:space-12}};
  --space-16:                 {{VALUE:space-16}};
  --space-20:                 {{VALUE:space-20}};
  --space-24:                 {{VALUE:space-24}};

  /* ─── Border Radii ─── */
  --radius-sm:                {{VALUE:radius-sm}};
  --radius-md:                {{VALUE:radius-md}};
  --radius-lg:                {{VALUE:radius-lg}};
  --radius-full:              {{VALUE:radius-full}};

  /* ─── Easing Curves ─── */
  --ease-out:                 {{VALUE:ease-out}};
  --ease-in-out:              {{VALUE:ease-in-out}};
  --ease-bounce:              {{VALUE:ease-bounce}};

  /* ─── Transition Durations ─── */
  --duration-fast:            {{VALUE:duration-fast}};
  --duration-base:            {{VALUE:duration-base}};
  --duration-slow:            {{VALUE:duration-slow}};

  /* ─── Shadows ─── */
  --shadow-sm:                {{VALUE:shadow-sm}};
  --shadow-md:                {{VALUE:shadow-md}};
  --shadow-lg:                {{VALUE:shadow-lg}};
  --shadow-glow:              {{VALUE:shadow-glow}};

  /* ─── Z-Index ─── */
  --z-dropdown:               {{VALUE:z-dropdown}};
  --z-sticky:                 {{VALUE:z-sticky}};
  --z-modal:                  {{VALUE:z-modal}};
  --z-toast:                  {{VALUE:z-toast}};
}
